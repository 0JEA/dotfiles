# ==============================================================================
# TMUX CONFIGURATION (.tmux.conf)
# ==============================================================================
# This configuration file defines the look, feel, and behavior of tmux.
# It is designed to be easily modified by LLMs and human users.
# ==============================================================================

# --- TERMINAL & COLOR SETTINGS ---
# Use screen-256color for broad compatibility
set -g default-terminal "screen-256color"
# Enable RGB/TrueColor support
set -ag terminal-overrides ",xterm-256color:RGB"

# --- KEY BINDINGS ---
# Set the prefix to Ctrl-a (more ergonomic than Ctrl-b)
set -g prefix C-a
unbind C-b
bind-key C-a send-prefix

# Reload config with 'r' key (useful for rapid testing)
bind r source-file ~/.tmux.conf \; display-message "Config reloaded!"

# --- MOUSE & STATUS BEHAVIOR ---
set -g mouse on
set -g status off
set -g destroy-unattached on # Kill session when terminal window is closed

# --- TOKYO NIGHT PRO PALETTE (Reference) ---
# BG: {{ colors.bg_source.default.hex }} | BLUE: {{ colors.blue_source.default.hex }} | CYAN: {{ colors.cyan_source.default.hex }} | MAGENTA: {{ colors.magenta_source.default.hex }} | GRAY: {{ colors.gray2_source.default.hex }}

# --- MESSAGE & BORDER STYLING ---
# Colors used for messages (like "Config reloaded!") and pane borders.
set -g message-style "fg={{ colors.blue_source.default.hex }},bg={{ colors.gray2_source.default.hex }},bold"
set -g pane-border-style "fg={{ colors.gray2_source.default.hex }}"
set -g pane-active-border-style "fg={{ colors.blue_source.default.hex }}"

# --- PLUGIN MANAGEMENT (TPM) ---
# TPM: Tmux Plugin Manager
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'

# Initialize TPM (Keep this at the very bottom of the file)
run '~/.tmux/plugins/tpm/tpm'
